# Block all direct web access to the admin/ folder.
# This protects config.php (DB password, eBay API secrets) in case the
# folder ends up inside the public web root on shared hosting.

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>
